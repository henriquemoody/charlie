{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "speckit-commands": {
      "type": "local",
      "command": [
        "node",
        "./.speckit/speckit-mcp-server.js"
      ],
      "environment": {
        "SPEC_KIT_ROOT": "."
      }
    },
    "speckit-filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    }
  }
}