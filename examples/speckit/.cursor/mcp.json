{
  "mcpServers": {
    "speckit-commands": {
      "command": "node",
      "args": [
        "./.speckit/speckit-mcp-server.js"
      ],
      "env": {
        "SPEC_KIT_ROOT": "."
      }
    },
    "speckit-filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    }
  }
}
